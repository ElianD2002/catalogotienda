            >
              <path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path>
            </svg>
          </a>

          <!-- Instagram -->
          <a
            id="footer-instagram"
            href={instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-full bg-stone-50 border border-stone-200 text-stone-700 hover:bg-neutral-950 hover:text-white transition-all duration-300 active:scale-95"
            aria-label="Instagram"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
              ></path>
            </svg>
          </a>
        </div>

        <!-- Copyright -->
        <p class="mt-8 font-sans text-[10px] tracking-wide text-stone-400">
          © {new Date().getFullYear()} {tituloHero}. Todos los derechos reservados.
        </p>
      </div>
    </footer>



    <!-- ════════════════════════════════════════════════ -->
    <!-- LIGHTBOX MODAL (ZOOM DE IMAGEN)                  -->
    <!-- ════════════════════════════════════════════════ -->
    <div
      id="image-lightbox"
      class="fixed inset-0 z-[100] flex hidden items-center justify-center bg-black/85 p-4 opacity-0 transition-opacity duration-300 backdrop-blur-sm"
    >
      <!-- Botón cerrar -->
      <button
        id="close-lightbox"
        class="absolute top-4 right-4 z-[110] flex h-12 w-12 items-center justify-center rounded-full bg-white/15 text-white transition-all duration-200 hover:bg-white/30 hover:scale-110 active:scale-95"
        aria-label="Cerrar vista ampliada"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <!-- Contenedor imagen -->
      <div
        id="lightbox-content"
        class="relative max-h-[90vh] max-w-[95vw] overflow-hidden rounded-2xl shadow-2xl ring-1 ring-white/10 transition-transform duration-300 scale-90"
      >
        <img
          id="lightbox-img"
          src=""
          alt=""
          class="block max-h-[80vh] max-w-[90vw] object-contain"
        />
        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent px-6 py-5 text-white">
          <h3 id="lightbox-title" class="text-lg font-bold drop-shadow"></h3>
          <p class="text-sm text-white/70 mt-0.5">Toca fuera de la imagen para cerrar</p>
        </div>
      </div>
    </div>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        var lightbox = document.getElementById("image-lightbox");
        var lightboxContent = document.getElementById("lightbox-content");
        var lightboxImg = document.getElementById("lightbox-img");
        var lightboxTitle = document.getElementById("lightbox-title");
        var closeBtn = document.getElementById("close-lightbox");
        var zoomableImgs = document.querySelectorAll(".product-zoomable-img");

        function openLightbox(src, title) {
          if (!lightbox || !lightboxImg || !lightboxTitle || !lightboxContent) return;

          lightboxImg.src = src;
          lightboxImg.alt = title;
          lightboxTitle.textContent = title;

          lightbox.classList.remove("hidden");
          void lightbox.offsetWidth; // reflow para activar transición
          lightbox.classList.add("opacity-100");
          lightboxContent.classList.remove("scale-90");
          lightboxContent.classList.add("scale-100");

          document.body.style.overflow = "hidden";
        }

        function closeLightbox() {
          if (!lightbox || !lightboxContent) return;

          lightbox.classList.remove("opacity-100");
          lightboxContent.classList.remove("scale-100");
          lightboxContent.classList.add("scale-90");

          setTimeout(function () {
            lightbox.classList.add("hidden");
            document.body.style.overflow = "";
          }, 300);
        }

        // Click en imágenes de producto
        zoomableImgs.forEach(function (img) {
          img.addEventListener("click", function (e) {
            var zoomSrc = e.currentTarget.getAttribute("data-zoom-src");
            var title = e.currentTarget.getAttribute("data-product-name") || "";
            if (zoomSrc) {
              openLightbox(zoomSrc, title);
            }
          });
        });

        // Botón cerrar
        if (closeBtn) {
          closeBtn.addEventListener("click", closeLightbox);
        }

        // Click en el fondo oscuro (fuera de la imagen)
        if (lightbox) {
          lightbox.addEventListener("click", function (e) {
            if (e.target === lightbox) {
              closeLightbox();
            }
          });
        }

        // Tecla ESC
        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape" && lightbox && !lightbox.classList.contains("hidden")) {
            closeLightbox();
          }
        });
      });
    </script>
  </body>
</html>
