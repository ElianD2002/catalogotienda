    <!-- ════════════════════════════════════════════════ -->
    <footer
      id="contacto"
      class="border-t border-stone-200 bg-white"
    >
      <div class="mx-auto max-w-lg px-6 py-12 text-center">
        <h2 class="mb-2 font-serif text-lg font-normal tracking-wider text-neutral-950 uppercase">
          ¿Viste algo que te gusta? 🛍️
