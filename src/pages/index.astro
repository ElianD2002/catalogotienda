---
import "../styles/global.css";
import menuData from "../../content/landing/menu.json";

// ── Tipado del producto ──
interface Producto {
  nombre: string;
  precio: string;
  imagen?: string;
  disponible_hoy: boolean;
  categoria: string;
}

interface PuntoVenta {
  nombre: string;
  direccion: string;
  mapsUrl: string;
}

// ── Datos del menú y configuración ──
const tituloHero: string = menuData.tituloHero;
const subtituloHero: string = menuData.subtituloHero || "Tradición familiar en cada bocado. Directo de Olanchito, Honduras.";
const rawWhatsapp: string = menuData.whatsapp || "50499998888";
// Limpiar el número de WhatsApp: eliminar guiones, espacios y otros caracteres que no sean dígitos.
// Si el número tiene 8 dígitos (ej: 97075303), se le antepone el código de país 504.
let whatsapp: string = rawWhatsapp.replace(/\D/g, "");
if (whatsapp.length === 8) {
  whatsapp = "504" + whatsapp;
}
const facebook: string = menuData.facebook || "#";
const instagram: string = menuData.instagram || "#";
const seoDescription: string = menuData.seoDescription || "Los mejores chicharrones y asados de Olanchito, Honduras.";
const puntosVenta: PuntoVenta[] = menuData.puntosVenta || [];
const productos: Producto[] = menuData.productos || [];

// ── Filtros de productos ──
const masVendido = productos.filter(
  (p) => p.categoria === "🔥 ¡Lo Más Vendido!" && p.disponible_hoy
);
const catalogoCompleto = productos.filter(
  (p) => p.categoria === "✨ Catálogo Completo" && p.disponible_hoy
);

function buildWhatsAppLink(productName: string): string {
  const message = encodeURIComponent(
    `Hola! Me interesa comprar: ${productName}. ¿Está disponible?`
  );
  return `https://wa.me/${whatsapp}?text=${message}`;
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={seoDescription}
    />
    <meta name="theme-color" content="#f59e0b" />
    <link rel="icon" type="image/jpeg" href="/images/Logo.jpeg" />
    <title>{tituloHero} — Catálogo Digital</title>
  </head>

  <body class="min-h-screen bg-stone-50 text-neutral-950 antialiased">
    <!-- ════════════════════════════════════════════════ -->
    <!-- HERO SECTION                                     -->
    <!-- ════════════════════════════════════════════════ -->
    <header
      id="hero"
      class="relative overflow-hidden bg-stone-50 py-24 border-b border-stone-200"
    >
      <div
        class="relative mx-auto flex max-w-lg flex-col items-center justify-center px-6 text-center"
      >
        <!-- Category/Badge above logo -->
        <span class="animate-fade-in-up text-[10px] font-bold tracking-[0.3em] text-neutral-400 uppercase mb-4">Colección Exclusiva</span>

        <!-- Logo/Icon -->
        <div
          class="animate-float mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-neutral-950 text-2xl shadow-md"
        >
          🛍️
        </div>

        <!-- Título principal -->
        <h1
          class="animate-fade-in-up font-serif text-3xl sm:text-4xl font-light tracking-widest text-neutral-950 uppercase mb-4"
        >
          {tituloHero}
        </h1>

        <!-- Fino separador horizontal -->
        <div class="w-12 h-[1px] bg-neutral-900 my-6 animate-fade-in-up"></div>

        <!-- Subtítulo -->
        <p
          class="animate-fade-in-up-delay mb-8 font-sans font-light text-xs tracking-wide text-neutral-500 max-w-xs leading-relaxed"
          set:html={subtituloHero.replace(/\n/g, "<br />")}
        />

        <!-- CTA Button -->
        <a
          id="hero-cta"
          href="#menu"
          class="animate-fade-in-up-delay inline-flex items-center gap-2 rounded-full border border-neutral-950 bg-neutral-950 text-white hover:bg-transparent hover:text-neutral-950 text-[10px] font-semibold uppercase tracking-widest px-8 py-3.5 transition-all duration-300"
        >
          <span>Ver Catálogo</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
      </div>
    </header>

    <main id="menu" class="mx-auto max-w-lg px-4 pb-24">
      <!-- ════════════════════════════════════════════════ -->
      <!-- SECCIÓN: 🔥 ¡LO MÁS VENDIDO!                      -->
      <!-- ════════════════════════════════════════════════ -->
      <section id="mas-vendido" class="py-12 border-b border-stone-200/60">
        <div class="mb-10 text-center">
          <span class="text-[10px] font-bold tracking-[0.3em] text-neutral-400 uppercase">Tendencias</span>
          <h2 class="font-serif text-2xl font-normal tracking-widest text-neutral-950 uppercase mt-1">
            ¡Lo Más Vendido!
          </h2>
          <div class="w-8 h-[1px] bg-stone-300 mx-auto mt-4"></div>
        </div>

        {
          masVendido.length > 0 ? (
            <div class="grid grid-cols-2 gap-x-4 gap-y-8">
              {masVendido.map((producto) => (
                <article
                  class="group relative flex flex-col justify-between overflow-hidden bg-transparent"
                >
                  <div class="flex flex-col">
                    {/* Product Image Container */}
                    <div class="relative aspect-[3/4] w-full overflow-hidden rounded-lg bg-stone-100 border border-stone-200/50 shadow-sm flex items-center justify-center transition-all duration-300 group-hover:shadow-md group-hover:border-stone-300">
                      {producto.imagen ? (
                        <img
                          src={producto.imagen}
                          alt={producto.nombre}
                          class="product-zoomable-img h-full w-full object-cover cursor-zoom-in transition-transform duration-500 group-hover:scale-105"
                          loading="lazy"
                          data-zoom-src={producto.imagen}
                          data-product-name={producto.nombre}
                        />
                      ) : (
                        <div class="flex h-full w-full items-center justify-center text-4xl">
                          🛍️
                        </div>
                      )}
                      {/* Badge "Top" */}
                      <span class="absolute right-2 top-2 rounded-md bg-neutral-950 px-2 py-0.5 text-[9px] font-semibold uppercase tracking-widest text-white shadow-sm">
                        Top
                      </span>
                    </div>

                    {/* Product Info below image */}
                    <h3 class="truncate font-serif text-sm font-semibold tracking-wide text-neutral-900 uppercase mt-3">
                      {producto.nombre}
                    </h3>
                    <p class="text-xs font-bold text-amber-800 mt-1">
                      {producto.precio}
                    </p>
                  </div>

                  {/* Action Button */}
                  <a
                    href={buildWhatsAppLink(producto.nombre)}
                    target="_blank"
                    rel="noopener noreferrer"
